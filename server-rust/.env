# ACDA-Q 后端环境变量配置模板
# 复制为 .env 后按需修改

# ===== 数据库 =====
# 主业务数据库 (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://quant:quant123@postgres:5432/quant_db
# 同步数据库连接 (用于 Celery Worker / Alembic)
SYNC_DATABASE_URL=postgresql://quant:quant123@postgres:5432/quant_db
# 时序数据库 (TimescaleDB)
TIMESCALE_DATABASE_URL=postgresql://quant:quant123@timescaledb:5432/quant_market

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== 安全密钥 =====
# 必须设置，至少 32 字符
# 生成方式: openssl rand -hex 32
SECRET_KEY=353633c65023529f2862b2dc43930abf6bdd734dc65154633ba40a42184b3300
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== CORS =====
# 开发环境可用 ["*"]，生产环境必须显式配置
CORS_ORIGINS=["*"]
COOKIE_SECURE=false

# ===== AI (DeepSeek) =====
DEEPSEEK_API_KEY=ENC:jkVJuVyyCkFE24gZd9b8F/RZnuyC1Cy4390Sf4wuYG+XZjWhP032DHqroa6uWYQ52RQ4Id0mUHsrZZc53YrT
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== MinIO (可选) =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ===== Tushare (数据同步) =====
TUSHARE_TOKEN=your-tushare-token
